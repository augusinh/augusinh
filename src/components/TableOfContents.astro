---
interface LangOption {
  label: string;
  id: string;
  href: string;
  current: boolean;
}
interface Props {
  headings?: { depth: number; slug: string; text: string }[];
  langs?: LangOption[];
}
const { headings = [], langs = [] } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const shortLabels: Record<string, string> = { 'Tiếng Việt': 'VI', 'English': 'EN' };
---
{toc.length > 0 && (
  <nav class="toc" aria-label="Mục lục">
    <button class="toc-trigger" type="button" aria-expanded="false">
      <svg class="toc-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
    <div class="toc-drawer">
      <div class="toc-drawer-head">
        <p class="toc-title">Mục lục</p>
        {langs.length > 0 && (
          <div class="toc-lang-row">
            {langs.map((l) => (
              <button
                type="button"
                class={`toc-lang ${l.current ? 'current' : ''}`}
                data-doc-id={l.id}
                data-href={l.href}
              >{shortLabels[l.label] ?? l.label}</button>
            ))}
          </div>
        )}
      </div>
      <ul>
        {toc.map((h) => (
          <li class={`toc-depth-${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>
        ))}
      </ul>
    </div>
  </nav>
)}
<script>
  const nav = document.querySelector<HTMLElement>('.toc');
  const trigger = nav?.querySelector<HTMLButtonElement>('.toc-trigger');
  const shell = document.querySelector<HTMLElement>('.article-shell');

  // Sync aria-expanded with initial open state (toc-open added server-side)
  if (shell?.classList.contains('toc-open')) {
    trigger?.setAttribute('aria-expanded', 'true');
  }

  // Click trigger → toggle open
  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = shell?.classList.toggle('toc-open') ?? false;
    trigger.setAttribute('aria-expanded', String(isOpen));
  });

  // Click outside → close
  document.addEventListener('click', (e) => {
    // Trang Tu Luật dùng TOC như bảng điều hướng cố định: click nội dung hoặc đổi theme
    // không được làm mất trạng thái người đọc đã chọn.
    if (document.body.classList.contains('page-tu-luat')) return;
    if (!nav?.contains(e.target as Node) && shell?.classList.contains('toc-open')) {
      shell.classList.remove('toc-open');
      trigger?.setAttribute('aria-expanded', 'false');
    }
  });

  // Click TOC link → close (navigated)
  nav?.querySelectorAll<HTMLAnchorElement>('.toc a').forEach((a) => {
    a.addEventListener('click', () => {
      shell?.classList.remove('toc-open');
      trigger?.setAttribute('aria-expanded', 'false');
    });
  });

  // IntersectionObserver — active link tracking
  const links = Array.from(nav?.querySelectorAll<HTMLAnchorElement>('.toc a') ?? []);
  if (links.length) {
    const map = new Map<string, HTMLAnchorElement>();
    links.forEach((l) => { const id = l.getAttribute('href')?.slice(1); if (id) map.set(id, l); });
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          links.forEach((l) => l.classList.remove('active'));
          map.get(e.target.id)?.classList.add('active');
        }
      });
    }, { rootMargin: '-80px 0px -70% 0px' });
    map.forEach((_, id) => { const el = document.getElementById(id); if (el) obs.observe(el); });
  }
</script>
