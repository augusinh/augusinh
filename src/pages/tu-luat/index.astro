---
import { getEntry } from 'astro:content';
import DocumentReader from '../../components/DocumentReader.astro';
const entry = await getEntry('documents', 'tu-luat-vi');
if (!entry) return Astro.redirect('/404');
---
<DocumentReader entry={entry} banner="tu-luat" langs={[
  { label: 'Tiếng Việt', href: '/tu-luat/', current: true, id: 'tu-luat-vi' },
  { label: 'English', href: '/tu-luat/en/', current: false, id: 'tu-luat-en' },
]} />
