---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuoteReel from '../../components/QuoteReel.astro';
import pageHeaders from '../../data/page-headers.json';
import ongoi from '../../data/on-goi-content.json';

const ph = (pageHeaders as Record<string, Record<string, string>>)['on-goi'];
const sections = ongoi.sections as any[];
const quotes   = ongoi.quotes as any[];
const [s0, s1, s2, s3] = sections;
---
<BaseLayout title="Ơn Gọi" bodyClass="no-sidebar og-page" banner={null}>

  <!-- BANNER — full-bleed, ngoài main.content ── -->
  <div slot="full-bleed" class="og-banner-outer">
    <div class="og-banner og-slider">
      <img src="/images/on-goi/banner.avif" alt="" class="og-slide active" loading="eager" />
      <img src="/images/on-goi/demo-1.jpg"  alt="" class="og-slide" loading="lazy" />
      <img src="/images/on-goi/demo-2.jpg"  alt="" class="og-slide" loading="lazy" />
      <header class="og-masthead">
        <div class="og-masthead-head">
          <p class="og-eyebrow"
             data-oe-target="ph" data-oe="eyebrow" data-oe-html="true"
             set:html={ph.eyebrow}></p>
          <h1 class="og-title"
              data-oe-target="ph" data-oe="title">{ph.title}</h1>
        </div>
        <img src="/images/emblem.svg" alt="" class="og-masthead-emblem" aria-hidden="true" />
        <div class="og-masthead-foot">
          <p class="og-masthead-quote bvq-text"
             data-oe-target="ph" data-oe="quote"
             set:html={ph.quote}></p>
          <cite class="og-masthead-cite bvq-cite"
             data-oe-target="ph" data-oe="cite" data-oe-html="true"
             set:html={ph.cite}></cite>
        </div>
      </header>
    </div>
  </div>

  <div class="og-content">

  <!-- VỀ DÒNG AUGUSTINÔ ────────────────────────── -->
  <section class="og-media" data-animate="slide-right">
    <figure class="og-media-img og-slider">
      <img class="og-slide active" src="/images/on-goi/demo-1.jpg" alt="Cộng đoàn Augustinô" loading="lazy" />
      <img class="og-slide" src="/images/on-goi/demo-3.jpg" alt="" loading="lazy" />
    </figure>
    <div class="og-media-body" data-animate="slide-left">
      <p class="og-label"
         data-oe-target="content" data-oe="sections.0.label">{s0.label}</p>
      <h2 class="og-media-title"
          data-oe-target="content" data-oe="sections.0.title">{s0.title}</h2>
      <p class="og-body"
         data-oe-target="content" data-oe="sections.0.paragraphs.0">{s0.paragraphs[0]}</p>
      <p class="og-body"
         data-oe-target="content" data-oe="sections.0.paragraphs.1">{s0.paragraphs[1]}</p>
      <a class="og-link" href={s0.link.href}
         data-oe-target="content" data-oe="sections.0.link.text">{s0.link.text}</a>
    </div>
  </section>

  <div class="og-divider" aria-hidden="true"><span></span><span class="og-div-gem">✦</span><span></span></div>

  <!-- THÁNH AUGUSTINÔ ──────────────────────────── -->
  <section class="og-aug-section" data-animate>
    <figure class="og-aug-portrait">
      <div class="aug-arch-frame">
        <img src="/db/saints/images/st-augustine-of-hippo.jpg" alt="Thánh Augustinô thành Hippô" loading="lazy" />
      </div>
      <figcaption
        data-oe-target="content" data-oe="sections.1.caption">{s1.caption}</figcaption>
    </figure>
    <div class="og-aug-body">
      <p class="og-label"
         data-oe-target="content" data-oe="sections.1.label">{s1.label}</p>
      <h2 class="og-media-title"
          data-oe-target="content" data-oe="sections.1.title">{s1.title}</h2>
      <p class="og-body"
         data-oe-target="content" data-oe="sections.1.paragraphs.0">{s1.paragraphs[0]}</p>
      <p class="og-body"
         data-oe-target="content" data-oe="sections.1.paragraphs.1">{s1.paragraphs[1]}</p>
      <a class="og-link" href={s1.link.href}
         data-oe-target="content" data-oe="sections.1.link.text">{s1.link.text}</a>
    </div>
  </section>

  <div class="og-divider" aria-hidden="true"><span></span><span class="og-div-gem">✦</span><span></span></div>

  <!-- ĐỜI SỐNG CỘNG ĐOÀN ─────────────────────── -->
  <section class="og-media og-media--flip" data-animate="slide-left">
    <div class="og-media-body" data-animate="slide-right">
      <p class="og-label"
         data-oe-target="content" data-oe="sections.2.label">{s2.label}</p>
      <h2 class="og-media-title"
          data-oe-target="content" data-oe="sections.2.title">{s2.title}</h2>
      <p class="og-body"
         data-oe-target="content" data-oe="sections.2.paragraphs.0">{s2.paragraphs[0]}</p>
      <p class="og-body"
         data-oe-target="content" data-oe="sections.2.paragraphs.1">{s2.paragraphs[1]}</p>
    </div>
    <figure class="og-media-img og-slider">
      <img class="og-slide active" src="/images/on-goi/demo-2.jpg" alt="Nhà nguyện cộng đoàn Augustinô" loading="lazy" />
    </figure>
  </section>

  <div class="og-divider" aria-hidden="true"><span></span><span class="og-div-gem">✦</span><span></span></div>

  <!-- HÀNH TRÌNH ƠN GỌI ──────────────────────── -->
  <section class="og-media" data-animate="slide-right">
    <figure class="og-media-img og-slider">
      <img class="og-slide active" src="/images/on-goi/demo-2.jpg" alt="Sinh hoạt hằng ngày tại cộng đoàn" loading="lazy" />
      <img class="og-slide" src="/images/on-goi/demo-1.jpg" alt="" loading="lazy" />
    </figure>
    <div class="og-media-body" data-animate="slide-left">
      <p class="og-label"
         data-oe-target="content" data-oe="sections.3.label">{s3.label}</p>
      <h2 class="og-media-title"
          data-oe-target="content" data-oe="sections.3.title">{s3.title}</h2>
      <ul class="og-steps">
        {s3.steps.map((step: any, i: number) => (
          <li>
            <svg class="og-step-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <line x1="8" y1="1.5" x2="8" y2="14.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              <line x1="2.5" y1="5.5" x2="13.5" y2="5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
            <strong data-oe-target="content" data-oe={`sections.3.steps.${i}.name`}>{step.name}</strong>
            <span   data-oe-target="content" data-oe={`sections.3.steps.${i}.desc`}>{step.desc}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <div class="og-divider og-divider--slim" aria-hidden="true"><span></span><span class="og-div-gem">✦</span><span></span></div>

  <!-- TRÍCH DẪN AUGUSTINÔ ─────────────────────── -->
  <div data-animate>
    <QuoteReel quotes={quotes} />
  </div>

  <div class="og-divider og-divider--slim" aria-hidden="true"><span></span><span class="og-div-gem">✦</span><span></span></div>

  <!-- CTA ────────────────────────────────────── -->
  <section class="og-cta" data-animate>
    <div class="og-cta-band">
      <div class="og-cta-seal">
        <img src="/images/emblem.svg"       alt="" class="og-cta-emblem og-cta-emblem--dark"  aria-hidden="true" />
        <img src="/images/emblem-color.png" alt="" class="og-cta-emblem og-cta-emblem--light" aria-hidden="true" />
        <p class="og-cta-org">OSA Việt Nam</p>
      </div>

      <span class="og-cta-vline" aria-hidden="true"></span>

      <div class="og-cta-contact">
        <p class="og-cta-contact-label">Liên Hệ Ơn Gọi</p>
        <a href="mailto:ongoi@augusinh.org" class="og-btn">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
          Gửi email
        </a>
        <a href="mailto:ongoi@augusinh.org" class="og-cta-email">ongoi@augusinh.org</a>
      </div>

      <span class="og-cta-vline" aria-hidden="true"></span>

      <div class="og-ext-col">
        <p class="og-cta-contact-label">Tìm Hiểu Thêm</p>
        <a class="og-ext" href="https://www.augustinianorder.org/" target="_blank" rel="noopener noreferrer">
          <strong class="og-ext-name">Trung ương Dòng</strong>
          <span class="og-ext-url">augustinianorder.org ↗</span>
        </a>
        <a class="og-ext" href="https://www.osa.org.au/" target="_blank" rel="noopener noreferrer">
          <strong class="og-ext-name">Tỉnh Dòng Úc Châu</strong>
          <span class="og-ext-url">osa.org.au ↗</span>
        </a>
      </div>
    </div>
  </section>

  </div><!-- /og-content -->

  <!-- INLINE EDIT TOOLBAR (chỉ hiện khi admin server đang chạy) -->
  <div id="oe-bar" class="oe-bar" hidden>
    <button id="oe-edit-btn" class="oe-bar-btn">
      <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793z"/>
        <path d="M11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
      </svg>
      Chỉnh sửa
    </button>
    <div id="oe-save-row" class="oe-save-row" hidden>
      <span id="oe-msg" class="oe-msg"></span>
      <button id="oe-cancel-btn" class="oe-bar-btn oe-bar-cancel">Huỷ</button>
      <button id="oe-save-btn" class="oe-bar-btn oe-bar-save">Lưu</button>
    </div>
  </div>

</BaseLayout>

<style is:global>
/* ── Page tokens ── */
.og-page { --og-rule: rgba(233,193,118,0.14); }

body.og-page main.content { padding-left: 0; padding-right: 0; }

.og-content {
  padding: 0 3rem;
}

/* ══ BANNER ════════════════════════════════════ */
.og-banner {
  position: relative;
  min-height: 95vh;
  display: flex; align-items: stretch; justify-content: flex-end;
  margin-top: -6.93rem;
  overflow: hidden;
}
.og-banner .og-slide { z-index: 0; filter: none; }
.og-banner::after {
  content: '';
  position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    transparent 35%,
    rgba(10,18,36,0.55) 68%,
    var(--bg-main) 100%
  );
}
.og-masthead {
  position: relative; z-index: 2;
  text-align: center;
  width: 50%;
  padding: 7.5rem 4rem 4rem;
  display: flex; flex-direction: column;
  align-items: center; justify-content: flex-start;
  background: rgba(8,14,30,0.40);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  border-left: 1px solid rgba(233,193,118,0.14);
  -webkit-mask-image: linear-gradient(to bottom, black 0%, black 72%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 0%, black 72%, transparent 100%);
  opacity: 0;
  transform: translateX(2.5rem);
  transition: opacity 0.9s cubic-bezier(0.22,1,0.36,1) 0.5s,
              transform 0.9s cubic-bezier(0.22,1,0.36,1) 0.5s;
}
.og-masthead.is-visible {
  opacity: 1;
  transform: translateX(0);
}
.og-masthead-head {
  flex: 1;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  width: 100%;
}
.og-masthead-emblem {
  width: 14.52rem; height: 14.52rem;
  object-fit: contain;
  opacity: 0.55;
  filter: brightness(0) invert(1) sepia(1) saturate(3) hue-rotate(5deg) brightness(0.85);
  margin: 0 auto 1.6rem;
  display: block;
  flex-shrink: 0;
}
.og-masthead-foot {
  width: 100%;
  text-align: center;
}
.og-eyebrow {
  font-family: 'Be Vietnam Pro', 'Manrope', system-ui, sans-serif;
  font-size: 0.95rem; font-weight: 700; letter-spacing: 0.2em;
  text-transform: uppercase; color: #e9c176;
  margin: 0 0 1.26rem;
  text-shadow: 0 1px 10px rgba(0,0,0,0.8);
  line-height: 1.7;
}
.og-title {
  font-family: 'Playfair Display', 'Noto Serif', serif;
  font-size: clamp(3.96rem, 2.7rem + 3.15vw, 6.84rem);
  line-height: 1.1; font-weight: 700;
  margin: 0 0 2rem; letter-spacing: 0.01em;
  background: linear-gradient(160deg, #ffffff 0%, #fff4d6 25%, #f4d98f 55%, #e9c176 80%, #d4a84b 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  filter: drop-shadow(0 0 28px rgba(233,193,118,0.7)) drop-shadow(0 2px 10px rgba(0,0,0,0.5));
}
/* masthead quote — compact, align bottom */
.og-masthead-quote {
  font-size: 1.62rem;
  line-height: 1.6;
  font-style: italic;
  font-weight: 300;
  color: #fff8ef;
  margin: 0 auto 0.5rem;
  max-width: 46rem;
  letter-spacing: 0.01em;
  text-shadow:
    0 2px 16px rgba(0,0,0,0.9),
    0 0 48px rgba(233,193,118,0.28),
    0 0 80px rgba(233,193,118,0.12);
}
.og-masthead-cite {
  font-size: 0.92rem;
  letter-spacing: 0.1em;
  color: #e9c176;
  margin: 0;
  text-shadow: 0 1px 6px rgba(0,0,0,0.6);
}
.og-masthead-cite em { color: #e9c176; }

/* ══ DIVIDER ════════════════════════════════════ */
.og-divider {
  display: flex; align-items: center; gap: 1.6rem;
  padding: 2.4rem 0;
}
.og-divider span:not(.og-div-gem) {
  flex: 1; height: 1px;
  background: linear-gradient(
    to var(--div-dir, right),
    transparent 0%,
    rgba(233,193,118,0.35) 40%,
    rgba(233,193,118,0.5) 100%
  );
}
.og-divider span:not(.og-div-gem):first-child {
  --div-dir: right;
  background: linear-gradient(to right, transparent 0%, rgba(233,193,118,0.5) 100%);
}
.og-divider span:not(.og-div-gem):last-child {
  background: linear-gradient(to left, transparent 0%, rgba(233,193,118,0.5) 100%);
}
.og-div-gem {
  font-size: 0.75rem; color: var(--gold);
  opacity: 0.55; flex-shrink: 0; line-height: 1;
  letter-spacing: 0.5em; padding-left: 0.5em;
}
/* slim — chỉ gem, không có lines */
.og-divider--slim {
  padding: 1rem 0;
  justify-content: center;
}
.og-divider--slim > span:not(.og-div-gem) { display: none; }
.og-divider--slim .og-div-gem {
  font-size: 0.7rem; opacity: 0.4;
  letter-spacing: 0.7em; padding-left: 0.7em;
}
/* light mode */
:global([data-theme="light"]) .og-divider span:not(.og-div-gem):first-child {
  background: linear-gradient(to right, transparent 0%, rgba(26,94,60,0.4) 100%);
}
:global([data-theme="light"]) .og-divider span:not(.og-div-gem):last-child {
  background: linear-gradient(to left, transparent 0%, rgba(26,94,60,0.4) 100%);
}
:global([data-theme="light"]) .og-div-gem { color: var(--accent); opacity: 0.65; }

/* ══ SHARED LABEL → overrides.css ═══════════════ */

/* ══ MEDIA SECTIONS ═════════════════════════════ */
.og-media {
  display: grid; grid-template-columns: 1fr 1fr;
  min-height: 46.8rem;
  margin: 2.16rem -3rem;
}
.og-media--flip .og-media-img { order: 2; }
.og-media--flip .og-media-body { order: 1; }

.og-media-img {
  margin: 0; overflow: hidden; position: relative;
}

.og-slide {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  opacity: 0; filter: brightness(0.88);
  transition: opacity 1s ease;
}
.og-slide.active { opacity: 1; }

.og-media-body {
  padding: 5.04rem 5.04rem 5.04rem 5.76rem;
  display: flex; flex-direction: column; justify-content: center;
  background: var(--bg-main);
}
.og-media--flip .og-media-body { padding: 5.04rem 5.76rem 5.04rem 5.04rem; }

.og-media-title {
  font-family: 'Noto Serif', 'Playfair Display', serif;
  font-size: clamp(2.38rem, 1.58rem + 1.98vw, 3.56rem);
  color: var(--ink-cream); margin: 0 0 1.8rem;
  letter-spacing: -0.01em; line-height: 1.2;
}
.og-body {
  font-family: 'Merriweather', serif;
  font-size: 1.68rem; line-height: 1.9;
  color: var(--ink-cream-soft); margin: 0 0 1.26rem;
}
.og-body:last-of-type { margin-bottom: 2.16rem; }
.og-link {
  font-family: 'Be Vietnam Pro', 'Manrope', system-ui, sans-serif;
  font-size: 1.22rem; font-weight: 600; letter-spacing: 0.05em;
  color: var(--accent); text-decoration: none;
  border-bottom: 1px solid var(--border-subtle);
  padding-bottom: 0.15rem; width: fit-content;
  transition: color 0.18s, border-color 0.18s;
}
.og-link:hover { color: var(--accent-deep); border-color: var(--accent); }

/* ══ AUGUSTINÔ SECTION ════════════════════════ */
.og-aug-section {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 5rem;
  align-items: center;
  padding: 3.6rem 2rem;
  max-width: 102rem;
  margin: 0 auto;
}
.og-aug-portrait {
  flex-shrink: 0;
  text-align: center;
  margin: 0;
}
.aug-arch-frame {
  width: clamp(14rem, 16vw, 19rem);
  border-radius: 50% 50% 8px 8px / 38% 38% 8px 8px;
  overflow: hidden;
  border: 1px solid rgba(233,193,118,0.28);
  box-shadow: 0 16px 52px rgba(0,0,0,0.55), 0 0 0 3px rgba(233,193,118,0.06);
  transition: box-shadow 0.4s;
}
.aug-arch-frame:hover {
  box-shadow: 0 20px 60px rgba(0,0,0,0.65), 0 0 0 3px rgba(233,193,118,0.14);
}
.aug-arch-frame img {
  display: block; width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover; object-position: center top;
  filter: saturate(0.88);
  transition: filter 0.4s, transform 0.5s;
}
.aug-arch-frame:hover img { filter: saturate(1.05); transform: scale(1.03); }
.og-aug-portrait figcaption {
  font-family: 'Be Vietnam Pro', 'Manrope', system-ui, sans-serif;
  font-size: 1.1rem; color: var(--ink-cream-soft);
  margin-top: 1rem; letter-spacing: 0.05em; opacity: 0.88;
  width: clamp(14rem, 16vw, 19rem);
  text-align: center;
  white-space: pre-line;
}
.og-aug-body {
  display: flex; flex-direction: column; justify-content: center;
}

@media (max-width: 700px) {
  .og-aug-section {
    grid-template-columns: 1fr;
    justify-items: center;
    gap: 2.8rem;
    padding: 2.8rem 0;
  }
  .aug-arch-frame { width: clamp(12rem, 50vw, 16rem); }
}

/* ══ QUOTE REEL ═════════════════════════════════ */
.og-page .bvq-text {
  font-size: 1.78rem;
  font-style: normal;
}

/* ══ STEPS ═════════════════════════════════════ */
.og-steps {
  list-style: none; padding: 0; margin: 2.4rem 0 0;
}
.og-steps li {
  display: grid;
  grid-template-columns: 2.6rem 1fr;
  grid-template-rows: auto auto;
  column-gap: 1.4rem;
  padding: 1.7rem 0;
  border-top: 1px solid var(--border-subtle);
  transition: border-color 0.2s;
}
.og-steps li:last-child { border-bottom: 1px solid var(--border-subtle); }
.og-steps li:hover { border-top-color: var(--border-accent); }
.og-step-icon {
  grid-column: 1; grid-row: 1 / 3;
  width: 1.5rem; height: 1.5rem;
  color: var(--accent); opacity: 0.45;
  align-self: start; margin-top: 0.35rem; flex-shrink: 0;
  transition: opacity 0.2s;
}
.og-steps li:hover .og-step-icon { opacity: 0.85; }
.og-steps strong {
  grid-column: 2; grid-row: 1;
  font-family: 'Noto Serif', serif;
  font-size: 1.78rem; font-weight: 600;
  color: var(--ink-cream); line-height: 1.3;
  display: block; margin-bottom: 0.45rem;
  transition: color 0.18s;
}
.og-steps li:hover strong { color: var(--accent); }
.og-steps span {
  grid-column: 2; grid-row: 2;
  font-family: 'Merriweather', serif;
  font-size: 1.5rem; line-height: 1.88;
  color: var(--ink-cream-soft); display: block;
}

/* ══ CTA ════════════════════════════════════════ */
.og-page .bv-quotes { margin-bottom: 2rem; }
.og-cta {
  padding: 0;
  text-align: center;
}
.og-cta-band {
  display: flex; align-items: center; justify-content: center;
  max-width: 80rem; margin: 0 auto;
  padding: 3.6rem 5rem;
  gap: 0;
}
.og-cta-seal {
  display: flex; flex-direction: column; align-items: center;
  gap: 1rem; flex: 0 0 16rem;
}
.og-cta-emblem {
  width: 15rem; height: 15rem;
  object-fit: contain;
}
.og-cta-emblem--dark {
  opacity: 0.72;
  filter: brightness(0) invert(1) sepia(1) saturate(4) hue-rotate(5deg) brightness(0.82);
}
.og-cta-emblem--light { display: none; border-radius: 6px; }
.og-cta-org {
  font-family: 'Be Vietnam Pro', 'Manrope', system-ui, sans-serif;
  font-size: 1.05rem; font-weight: 600; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--label-color);
  margin: 0; text-align: center;
}
.og-cta-vline {
  width: 1px; align-self: stretch;
  background: var(--border-accent);
  margin: 0 4rem; flex-shrink: 0;
}
.og-cta-contact {
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 1.1rem; flex: 0 0 auto;
}
/* og-cta-contact-label → overrides.css */
.og-btn {
  font-family: 'Be Vietnam Pro', 'Manrope', system-ui, sans-serif;
  font-size: 1.2rem; font-weight: 600; letter-spacing: 0.05em;
  background: transparent; color: var(--gold);
  border: 1.5px solid rgba(233,193,118,0.55);
  text-decoration: none; padding: 0.85rem 2.4rem;
  border-radius: 100px; white-space: nowrap;
  display: inline-flex; align-items: center; gap: 0.6rem;
  transition: background 0.2s, color 0.2s, border-color 0.2s;
}
.og-btn:hover { background: var(--gold); color: #101b33; border-color: var(--gold); }
.og-cta-email {
  font-family: 'Be Vietnam Pro', 'Manrope', system-ui, sans-serif;
  font-size: 1.2rem; font-weight: 500; letter-spacing: 0.03em;
  color: var(--ink-cream); text-decoration: none;
  border-bottom: 1px solid var(--border-subtle); padding-bottom: 0.1rem;
  transition: color 0.18s, border-color 0.18s;
}
.og-cta-email:hover { color: var(--accent); border-color: var(--accent); }
.og-ext-col {
  display: flex; flex-direction: column; gap: 1.6rem;
  flex: 0 0 auto; min-width: 18rem;
}
.og-ext {
  display: flex; flex-direction: column; gap: 0.25rem;
  text-decoration: none; transition: none;
}
.og-ext-name {
  font-family: 'Noto Serif', serif;
  font-size: 1.85rem; line-height: 1.3; color: var(--ink-cream-soft);
  font-weight: 500; transition: color 0.2s;
}
.og-ext:hover .og-ext-name { color: var(--accent); }
.og-ext-url {
  font-family: 'Be Vietnam Pro', 'Manrope', system-ui, sans-serif;
  font-size: 1.1rem; font-weight: 500; letter-spacing: 0.02em;
  color: var(--gold-dim); opacity: 0.85;
  border-bottom: 1px solid var(--border-subtle);
  padding-bottom: 0.05rem;
  transition: color 0.2s, opacity 0.2s, border-color 0.2s;
}
.og-ext:hover .og-ext-url { opacity: 1; color: var(--accent); border-color: var(--border-accent); }

/* ══ SCROLL ANIMATIONS ══════════════════════════ */
.og-page [data-animate] {
  opacity: 0;
  transform: translateY(32px);
  transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1),
              transform 0.7s cubic-bezier(0.22,1,0.36,1);
}
.og-page [data-animate="slide-right"] { transform: translateX(-36px); }
.og-page [data-animate="slide-left"]  { transform: translateX(36px); }
.og-page [data-animate].is-visible    { opacity: 1; transform: none; }

/* OE toolbar CSS → overrides.css */

/* ══ LIGHT MODE → tất cả trong overrides.css ════ */

/* ══ RESPONSIVE ══════════════════════════════════ */
@media (max-width: 900px) {
  .og-content { padding: 0 3.2rem; }
  .og-media { margin: 2.16rem -3.2rem; grid-template-columns: 1fr; min-height: unset; }
  .og-media--flip .og-media-img  { order: unset; }
  .og-media--flip .og-media-body { order: unset; }
  .og-media-img { aspect-ratio: 16/9; min-height: 23.4rem; }
  .og-media-body,
  .og-media--flip .og-media-body { padding: 3.6rem 2.88rem; }
  .og-cta-band { margin: 0 -3.2rem; padding: 3rem 3.2rem; flex-wrap: wrap; gap: 2.4rem; }
  .og-cta-vline { display: none; }
  .og-cta-seal { flex-direction: row; flex: 0 0 100%; justify-content: center; gap: 1.6rem; }
}
@media (max-width: 600px) {
  .og-content { padding: 0 2rem; }
  .og-media { margin: 2.16rem -2rem; }
  .og-media-body,
  .og-media--flip .og-media-body { padding: 2.88rem 1.8rem; }
  .og-cta-band { margin: 0 -2rem; padding: 2.8rem 2rem; flex-direction: column; align-items: flex-start; }
  .og-cta-seal { flex: unset; flex-direction: row; align-items: center; }
}
</style>

<script define:vars={{ ongoiJson: ongoi, phJson: ph }}>
// ── Prevent BaseLayout auto-scroll ──────────────────────────────
document.body.dataset.noAutoscroll = 'true';

// ── Masthead slide-in ────────────────────────────────────────────
const masthead    = document.querySelector('.og-masthead');
const bannerEl    = document.querySelector('.og-banner');
const activeSlide = document.querySelector('.og-banner .og-slide.active');

function showMasthead() {
  if (!masthead) return;
  masthead.classList.remove('is-visible');
  requestAnimationFrame(() => requestAnimationFrame(() => masthead.classList.add('is-visible')));
}
function initMastheadOnScroll() {
  if (!masthead || !bannerEl) return;
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) showMasthead();
      else masthead.classList.remove('is-visible');
    });
  }, { threshold: 0.15 });
  obs.observe(bannerEl);
}
if (masthead) {
  if (!activeSlide || (activeSlide.complete && activeSlide.naturalHeight > 0)) {
    initMastheadOnScroll();
  } else {
    const fb = setTimeout(initMastheadOnScroll, 4000);
    activeSlide.addEventListener('load',  () => { clearTimeout(fb); initMastheadOnScroll(); }, { once: true });
    activeSlide.addEventListener('error', () => { clearTimeout(fb); initMastheadOnScroll(); }, { once: true });
  }
}

// ── Scroll reveal ────────────────────────────────────────────────
const revealObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) e.target.classList.add('is-visible');
    else e.target.classList.remove('is-visible');
  });
}, { threshold: 0.07, rootMargin: '0px 0px -48px 0px' });
document.querySelectorAll('[data-animate]').forEach(el => revealObs.observe(el));

// ── Auto-slide images ────────────────────────────────────────────
document.querySelectorAll('.og-slider').forEach(panel => {
  const imgs = Array.from(panel.querySelectorAll('.og-slide'));
  if (imgs.length <= 1) return;
  let idx = 0;
  setInterval(() => {
    imgs[idx].classList.remove('active');
    idx = (idx + 1) % imgs.length;
    imgs[idx].classList.add('active');
  }, 4500);
});

// ── Highlight "Thiên Chúa" / "Chúa" trong masthead quote ──────────
document.querySelectorAll('.og-masthead-quote').forEach(el => {
  el.innerHTML = el.innerHTML.replace(
    /Thiên Chúa|Chúa/gi,
    m => `<span class="bvq-lord">${m.toUpperCase()}</span>`
  );
});

// ── Inline edit ───────────────────────────────────────────────────
const ADMIN = 'http://localhost:4322';
const oeBar     = document.getElementById('oe-bar');
const oeEditBtn = document.getElementById('oe-edit-btn');
const oeSaveRow = document.getElementById('oe-save-row');
const oeCancelBtn = document.getElementById('oe-cancel-btn');
const oeSaveBtn   = document.getElementById('oe-save-btn');
const oeMsg       = document.getElementById('oe-msg');

// Detect admin server
fetch(ADMIN + '/api/on-goi', { method: 'GET' }).then(r => {
  if (r.ok && oeBar) oeBar.removeAttribute('hidden');
}).catch(() => {});

function setNested(obj, path, val) {
  const parts = path.split('.');
  let cur = obj;
  for (let i = 0; i < parts.length - 1; i++) {
    const k = /^\d+$/.test(parts[i]) ? +parts[i] : parts[i];
    cur = cur[k];
  }
  const last = parts[parts.length - 1];
  cur[/^\d+$/.test(last) ? +last : last] = val;
}

let editing = false;

function enterEditMode() {
  editing = true;
  document.body.classList.add('oe-editing');
  document.querySelectorAll('[data-oe]').forEach(el => {
    el.setAttribute('contenteditable', 'true');
    el.dataset.oeOrig = el.dataset.oeHtml ? el.innerHTML : el.textContent;
  });
  if (oeEditBtn) oeEditBtn.setAttribute('hidden', '');
  if (oeSaveRow) oeSaveRow.removeAttribute('hidden');
  if (oeMsg) oeMsg.textContent = '';
}

function exitEditMode() {
  editing = false;
  document.body.classList.remove('oe-editing');
  document.querySelectorAll('[data-oe]').forEach(el => {
    el.removeAttribute('contenteditable');
  });
  if (oeEditBtn) oeEditBtn.removeAttribute('hidden');
  if (oeSaveRow) oeSaveRow.setAttribute('hidden', '');
}

function cancelEdit() {
  document.querySelectorAll('[data-oe]').forEach(el => {
    const orig = el.dataset.oeOrig;
    if (orig !== undefined) {
      if (el.dataset.oeHtml) el.innerHTML = orig;
      else el.textContent = orig;
    }
  });
  exitEditMode();
}

async function saveEdit() {
  if (oeMsg) oeMsg.textContent = 'Đang lưu…';

  // Collect page-header fields
  const phData = Object.assign({}, phJson);
  document.querySelectorAll('[data-oe-target="ph"][data-oe]').forEach(el => {
    phData[el.dataset.oe] = el.dataset.oeHtml ? el.innerHTML.trim() : el.textContent.trim();
  });

  // Collect content fields (deep clone original, apply overrides)
  const contentData = JSON.parse(JSON.stringify(ongoiJson));
  document.querySelectorAll('[data-oe-target="content"][data-oe]').forEach(el => {
    const val = el.dataset.oeHtml ? el.innerHTML.trim() : el.textContent.trim();
    try { setNested(contentData, el.dataset.oe, val); } catch (err) {}
  });

  try {
    const [r1, r2] = await Promise.all([
      fetch(ADMIN + '/api/page-headers/on-goi', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(phData),
      }),
      fetch(ADMIN + '/api/on-goi', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(contentData),
      }),
    ]);
    if (r1.ok && r2.ok) {
      if (oeMsg) oeMsg.textContent = 'Đã lưu!';
      setTimeout(exitEditMode, 900);
    } else {
      if (oeMsg) oeMsg.textContent = 'Lỗi khi lưu';
    }
  } catch {
    if (oeMsg) oeMsg.textContent = 'Không kết nối được admin server';
  }
}

oeEditBtn  ?.addEventListener('click', enterEditMode);
oeCancelBtn?.addEventListener('click', cancelEdit);
oeSaveBtn  ?.addEventListener('click', saveEdit);
</script>
