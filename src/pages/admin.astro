---
import BaseLayout from '../layouts/BaseLayout.astro';

const SEASONS = [
  { key: 'le-chung',        label: 'Lễ Chung' },
  { key: 'le-rieng',        label: 'Lễ Riêng' },
  { key: 'trong-kinh-chua', label: 'Lễ Trọng Kính Chúa' },
  { key: 'mua-thuong-nien', label: 'Mùa Thường Niên' },
  { key: 'mua-vong',        label: 'Mùa Vọng' },
  { key: 'mua-giang-sinh',  label: 'Mùa Giáng Sinh' },
  { key: 'mua-chay',        label: 'Mùa Chay' },
  { key: 'mua-phuc-sinh',   label: 'Mùa Phục Sinh' },
];
---
<BaseLayout title="Admin" bodyClass="no-sidebar" banner={null}>
<div class="sb-wrap">

  <!-- HEADER -->
  <div class="sb-header">
    <div class="sb-title-row">
      <h1>Admin</h1>
      <button class="sb-btn-new" id="btnNew" style="display:none">+ Bài mới</button>
    </div>
    <div class="sb-tab-bar">
      <button class="sb-tab-btn active" data-panel="panelCaiDat">Cài Đặt Trang</button>
      <button class="sb-tab-btn" data-panel="panelKinhSach">Kinh Sách</button>
      <button class="sb-tab-btn" data-panel="panelSaints">Thánh Chân Phước</button>
    </div>
    <div id="sbAlert" class="sb-alert" style="display:none"></div>
  </div>

  <!-- PANEL: KINH SÁCH -->
  <div id="panelKinhSach" class="sb-panel" style="display:none">

  <!-- TRẠNG THÁI KẾT NỐI -->
  <div id="sbOffline" class="sb-offline" style="display:none">
    <div class="sb-offline-box">
      <div class="sb-offline-icon">⚠</div>
      <h2>Admin Server chưa chạy</h2>
      <p>Mở một terminal mới trong thư mục dự án và chạy lệnh:</p>
      <pre>npm run admin</pre>
      <p>Sau đó tải lại trang này.</p>
      <button id="btnRetry">Thử lại</button>
    </div>
  </div>

  <!-- MAIN UI -->
  <div id="sbMain" class="sb-main" style="display:none">

    <!-- SIDEBAR DANH SÁCH -->
    <aside class="sb-sidebar">
      <div class="sb-sidebar-toolbar">
        <select id="filterSeason">
          <option value="">Tất cả mùa</option>
          {SEASONS.map(s => <option value={s.key}>{s.label}</option>)}
        </select>
        <input id="filterSearch" type="search" placeholder="Tìm bài..." />
        <label class="sb-filter-check">
          <input type="checkbox" id="filterEmpty" />
          <span>Chỉ bài chưa có nội dung</span>
        </label>
      </div>
      <div class="sb-count" id="sbCount"></div>
      <div id="entryList" class="sb-entry-list"></div>
    </aside>

    <!-- KHU VỰC SOẠN BÀI -->
    <main class="sb-editor" id="sbEditor">
      <div class="sb-empty-state" id="editorEmpty">
        <div class="sb-empty-icon">✍</div>
        <p>Chọn một bài từ danh sách để chỉnh sửa,<br/>hoặc nhấn <strong>+ Bài mới</strong> để tạo bài.</p>
      </div>

      <form class="sb-form" id="sbForm" style="display:none" autocomplete="off">
        <div class="sb-form-header">
          <h2 id="formTitle">Chỉnh sửa bài</h2>
          <div class="sb-form-actions-top">
            <button type="button" class="sb-btn sb-btn-ghost" id="btnCancel">Hủy</button>
            <button type="button" class="sb-btn sb-btn-danger" id="btnDelete" style="display:none">Xóa</button>
            <button type="submit" class="sb-btn sb-btn-primary" id="btnSave">Lưu</button>
          </div>
        </div>

        <input type="hidden" id="fEditId" />

        <div class="sb-grid-2">
          <div class="sb-field">
            <label>Tên bài lễ <span class="req">*</span></label>
            <input id="fTitle" type="text" placeholder="vd: Lễ Thánh Augustinô, 28 tháng 8" required />
          </div>
          <div class="sb-field">
            <label>Mùa phụng vụ <span class="req">*</span></label>
            <select id="fSeason">
              {SEASONS.map(s => <option value={s.key}>{s.label}</option>)}
            </select>
          </div>
        </div>

        <div class="sb-grid-2">
          <div class="sb-field">
            <label>Tác giả <small>(source)</small></label>
            <input id="fSource" type="text" placeholder="vd: Thánh Augustinô, Gm. và Ts." />
          </div>
          <div class="sb-field">
            <label>Trích dẫn tác phẩm <small>(excerpt)</small></label>
            <input id="fExcerpt" type="text" placeholder="vd: Sermon 47, 1-3" />
          </div>
        </div>

        <div class="sb-field">
          <label>Tên đầy đủ trong bảng <small>(liturgy)</small></label>
          <input id="fLiturgy" type="text" placeholder="vd: Ngày 28 Tháng 8: Thánh Augustinô, Gm. và Ts." />
          <span class="sb-hint">Lễ Riêng: bắt đầu bằng "Ngày D Tháng M:" để hiển thị đúng trong Bài đọc hôm nay.</span>
        </div>

        <div class="sb-grid-3">
          <div class="sb-field">
            <label>Thứ tự <small>(order)</small></label>
            <input id="fOrder" type="number" value="1" min="1" />
          </div>
          <div class="sb-field">
            <label>Cấp bậc <small>(rank)</small></label>
            <input id="fRank" type="text" placeholder="solemn / feast / ..." />
          </div>
          <div class="sb-field sb-field-check sb-field-check-col">
            <label><input id="fDraft" type="checkbox" /> Lưu nháp (ẩn trên site)</label>
            <label><input id="fManualFill" type="checkbox" /> Đánh dấu <strong>fill tay</strong> (chuẩn hóa sau)</label>
          </div>
        </div>

        <div class="sb-field">
          <label>Slug (tên file) <span class="req">*</span></label>
          <div class="sb-slug-row">
            <span class="sb-slug-pfx" id="slugPfx">kinh-sach/le-chung/</span>
            <input id="fSlug" type="text" placeholder="ten-bai-doc" pattern="[a-z0-9\-]+" required />
            <span class="sb-slug-sfx">.md</span>
          </div>
          <span class="sb-hint">Chỉ dùng chữ thường, số và dấu gạch nối.</span>
        </div>

        <div class="sb-field sb-field-body">
          <label>Nội dung bài đọc <span class="req">*</span></label>
          <textarea id="fBody" rows="20" placeholder="Nhập nội dung bài đọc ở đây.
Dùng ## để bắt đầu chương/phần.
Dùng > để trích dẫn."></textarea>
        </div>

        <div class="sb-form-footer">
          <button type="button" class="sb-btn sb-btn-ghost" id="btnCancel2">Hủy</button>
          <button type="button" class="sb-btn sb-btn-danger" id="btnDelete2" style="display:none">Xóa bài này</button>
          <button type="submit" class="sb-btn sb-btn-primary">Lưu bài</button>
        </div>
      </form>
    </main>
  </div>

  </div>{/* end #panelKinhSach */}

  <!-- PANEL: THÁNH CHÂN PHƯỚC -->
  <div id="panelSaints" class="sb-panel" style="display:none">
    <div id="sbMainSaints" class="sb-main">
      <aside class="sb-sidebar">
        <div class="sb-sidebar-toolbar">
          <input id="saintSearch" type="search" placeholder="Tìm theo tên..." />
          <label class="sb-filter-check">
            <input type="checkbox" id="saintFilterEmpty" />
            <span>Chỉ bài chưa có nội dung</span>
          </label>
          <label class="sb-filter-check">
            <input type="checkbox" id="saintFilterManual" />
            <span>Chỉ đánh dấu fill tay</span>
          </label>
        </div>
        <div class="sb-count" id="saintCount"></div>
        <div id="saintList" class="sb-entry-list"></div>
      </aside>

      <main class="sb-editor" id="saintEditorWrap">
        <div class="sb-empty-state" id="saintEditorEmpty">
          <div class="sb-empty-icon">✝</div>
          <p>Chọn một mục từ danh sách để chỉnh sửa.</p>
        </div>

        <form class="sb-form" id="saintForm" style="display:none" autocomplete="off">
          <div class="sb-form-header">
            <h2 id="saintFormTitle">Chỉnh sửa tiểu sử</h2>
            <div class="sb-form-actions-top">
              <button type="button" class="sb-btn sb-btn-ghost" id="saintBtnCancel">Hủy</button>
              <button type="submit" class="sb-btn sb-btn-primary" id="saintBtnSave">Lưu</button>
            </div>
          </div>

          <input type="hidden" id="saintEditId" />

          <div class="sb-grid-2">
            <div class="sb-field">
              <label>Tên thánh <span class="req">*</span></label>
              <input id="saintTitle" type="text" required />
            </div>
            <div class="sb-field">
              <label>Phụ đề</label>
              <input id="saintSubtitle" type="text" />
            </div>
          </div>

          <div class="sb-grid-3">
            <div class="sb-field">
              <label>Cấp lễ <small>(rank)</small></label>
              <select id="saintRank">
                <option value="solemn">Lễ Trọng</option>
                <option value="feast">Lễ Kính</option>
                <option value="memorial">Lễ Nhớ</option>
                <option value="none">Không có</option>
              </select>
            </div>
            <div class="sb-field">
              <label>Ngày lễ</label>
              <input id="saintFeastDay" type="number" min="1" max="31" />
            </div>
            <div class="sb-field">
              <label>Tháng lễ</label>
              <input id="saintFeastMonth" type="number" min="1" max="12" />
            </div>
          </div>

          <div class="sb-field">
            <label>Tên file ảnh <small>(imageFile)</small></label>
            <input id="saintImageFile" type="text" placeholder="vd: st-augustine-of-hippo.jpg" />
          </div>

          <div class="sb-grid-2">
            <div class="sb-field sb-field-check sb-field-check-col">
              <label><input id="saintDraft" type="checkbox" /> Lưu nháp (ẩn trên site)</label>
              <label><input id="saintManualFill" type="checkbox" /> Đánh dấu <strong>fill tay</strong></label>
            </div>
          </div>

          <div class="sb-field sb-field-body">
            <label>Nội dung tiểu sử <span class="req">*</span></label>
            <textarea id="saintBody" rows="20" placeholder="Nhập nội dung tiểu sử ở đây."></textarea>
          </div>

          <div class="sb-form-footer">
            <button type="button" class="sb-btn sb-btn-ghost" id="saintBtnCancel2">Hủy</button>
            <button type="submit" class="sb-btn sb-btn-primary">Lưu</button>
          </div>
        </form>
      </main>
    </div>
  </div>{/* end #panelSaints */}

  <!-- PANEL: CÀI ĐẶT TRANG -->
  <div id="panelCaiDat" class="sb-panel">
    <div class="cd-wrap">
      <!-- SIDEBAR: chọn loại → chọn trang -->
      <aside class="cd-sidebar">
        <div class="cd-type-bar">
          <button class="cd-type-btn" data-group="banner">Banner</button>
          <button class="cd-type-btn" data-group="masthead">Tiêu đề trang</button>
        </div>
        <div id="cdPageList" class="cd-page-list"></div>
      </aside>

      <!-- EDITOR AREA -->
      <main class="cd-editor" id="cdEditor">
        <div class="sb-empty-state" id="cdEmpty">
          <div class="sb-empty-icon">⚙</div>
          <p>Chọn một trang để chỉnh sửa banner và tiêu đề.</p>
        </div>

        <div id="cdForm" style="display:none">
          <div class="cd-form-hd">
            <h2 id="cdFormTitle">Banner & Tiêu Đề</h2>
            <div class="sb-form-actions-top">
              <button type="button" class="sb-btn sb-btn-primary" id="cdSaveBtn">Lưu</button>
            </div>
          </div>

          <!-- BANNER SECTION -->
          <section class="cd-section" id="cdBannerSection">
            <h3 class="cd-section-title">Banner</h3>
            <div id="cdBannerNote" class="sb-hint" style="margin-bottom:1.2rem"></div>

            <div id="cdVariants"></div>

            <div class="cd-actions-row">
              <button type="button" class="sb-btn sb-btn-ghost" id="cdAddVariant" style="display:none">+ Thêm variant</button>
              <label class="cd-upload-btn" id="cdUploadLabel" title="Tải ảnh lên (jpg/png/webp, tối đa 8MB)">
                ↑ Tải ảnh lên
                <input type="file" id="cdUploadInput" accept=".jpg,.jpeg,.png,.webp,.avif,.gif,.svg" style="display:none" />
              </label>
              <span class="cd-upload-status" id="cdUploadStatus"></span>
            </div>
          </section>

          <!-- MASTHEAD SECTION -->
          <section class="cd-section" id="cdMastheadSection" style="display:none">
            <h3 class="cd-section-title">Tiêu Đề Trang (lib-masthead)</h3>
            <div id="cdMastheadFields"></div>
          </section>
        </div>
      </main>
    </div>
  </div>{/* end #panelCaiDat */}

</div>

<script define:vars={{ SEASONS }}>
const API = 'http://localhost:4322';

// ─── State ─────────────────────────────────────────────────────────────────
let allEntries = {};   // { seasonKey: [entry, ...] }
let currentId  = null; // id của bài đang mở
let isNew      = false;

// ─── DOM refs ──────────────────────────────────────────────────────────────
const $ = id => document.getElementById(id);
const els = {
  offline: $('sbOffline'), main: $('sbMain'), alert: $('sbAlert'),
  list: $('entryList'), count: $('sbCount'),
  filterSeason: $('filterSeason'), filterSearch: $('filterSearch'), filterEmpty: $('filterEmpty'),
  empty: $('editorEmpty'), form: $('sbForm'), formTitle: $('formTitle'),
  fId: $('fEditId'), fTitle: $('fTitle'), fSeason: $('fSeason'),
  fSource: $('fSource'), fExcerpt: $('fExcerpt'), fLiturgy: $('fLiturgy'),
  fOrder: $('fOrder'), fRank: $('fRank'), fDraft: $('fDraft'), fManualFill: $('fManualFill'),
  fSlug: $('fSlug'), slugPfx: $('slugPfx'), fBody: $('fBody'),
  btnDelete: $('btnDelete'), btnDelete2: $('btnDelete2'),
};

// ─── Helpers ───────────────────────────────────────────────────────────────
function toSlug(s) {
  return s.toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g,'')
    .replace(/đ/gi,'d').replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'');
}
function seasonLabel(key) {
  return SEASONS.find(s => s.key === key)?.label || key;
}
function showAlert(msg, type = 'success') {
  els.alert.textContent = msg;
  els.alert.className = 'sb-alert sb-alert-' + type;
  els.alert.style.display = 'block';
  setTimeout(() => els.alert.style.display = 'none', 4000);
}
async function api(method, path, body) {
  const opts = { method, headers: { 'Content-Type': 'application/json' } };
  if (body) opts.body = JSON.stringify(body);
  const r = await fetch(API + path, opts);
  const d = await r.json();
  if (!r.ok) throw new Error(d.error || r.statusText);
  return d;
}

// ─── Load entries ──────────────────────────────────────────────────────────
async function loadEntries() {
  allEntries = await api('GET', '/api/entries');
  renderList();
}

function renderList() {
  const filterKey   = els.filterSeason.value;
  const q           = els.filterSearch.value.toLowerCase().trim();
  const onlyEmpty   = els.filterEmpty.checked;
  const rows = [];
  for (const [sk, entries] of Object.entries(allEntries)) {
    if (filterKey && sk !== filterKey) continue;
    for (const e of entries) {
      if (q && !e.title.toLowerCase().includes(q) && !e.author.toLowerCase().includes(q) && !e.liturgy.toLowerCase().includes(q)) continue;
      if (onlyEmpty && e.hasContent) continue;
      rows.push({ ...e, seasonKey: sk });
    }
  }
  const totalEmpty = Object.values(allEntries).flat().filter(e => !e.hasContent).length;
  els.count.textContent = `${rows.length} bài${onlyEmpty ? '' : ` · ${totalEmpty} chưa có nội dung`}`;
  if (!rows.length) {
    els.list.innerHTML = '<p class="sb-list-empty">Không có bài nào.</p>';
    return;
  }
  const grouped = {};
  for (const r of rows) {
    if (!grouped[r.seasonKey]) grouped[r.seasonKey] = [];
    grouped[r.seasonKey].push(r);
  }
  els.list.innerHTML = Object.entries(grouped).map(([sk, entries]) => `
    <div class="sb-season-group">
      <div class="sb-season-label">${seasonLabel(sk)} <span>(${entries.length})</span></div>
      ${entries.map(e => `
        <div class="sb-entry-row ${e.id === currentId ? 'active' : ''} ${e.draft ? 'is-draft' : ''} ${!e.hasContent ? 'is-empty' : ''}"
             data-id="${e.id}">
          <div class="sb-entry-status" title="${e.hasContent ? 'Có nội dung' : 'Chưa có nội dung'}"></div>
          <div class="sb-entry-body">
            <div class="sb-entry-title">${esc(e.title)}</div>
            <div class="sb-entry-meta">
              ${e.author ? `<span>${esc(e.author)}</span>` : ''}
              ${e.draft ? '<span class="sb-tag sb-tag-draft">nháp</span>' : ''}
              ${!e.hasContent ? '<span class="sb-tag sb-tag-empty">trống</span>' : ''}
            </div>
          </div>
        </div>`).join('')}
    </div>`).join('');
}

const esc = s => String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

// ─── Open entry for editing ────────────────────────────────────────────────
async function openEntry(id) {
  currentId = id;
  isNew = false;
  const data = await api('GET', `/api/entry?id=${encodeURIComponent(id)}`);
  const fm = data.fm || {};
  const [sk, ...slugParts] = id.split('/');
  const slug = slugParts.join('/');
  els.fId.value        = id;
  els.fTitle.value     = fm.title   || '';
  els.fSeason.value    = fm.seasonKey || sk;
  els.fSource.value    = fm.source  || '';
  els.fExcerpt.value   = fm.excerpt || '';
  els.fLiturgy.value   = fm.liturgy || '';
  els.fOrder.value     = fm.order   ?? 1;
  els.fRank.value      = fm.rank    || '';
  els.fDraft.checked   = !!fm.draft;
  els.fManualFill.checked = !!fm.manualFill;
  els.fSlug.value      = slug;
  els.fSlug._manual    = true;
  els.fBody.value      = data.body  || '';
  els.slugPfx.textContent = `kinh-sach/${fm.seasonKey || sk}/`;
  els.formTitle.textContent = 'Chỉnh sửa bài';
  els.btnDelete.style.display = 'inline-flex';
  els.btnDelete2.style.display = 'inline-flex';
  els.empty.style.display = 'none';
  els.form.style.display  = 'block';
  renderList();
}

function openNew() {
  currentId = null;
  isNew = true;
  els.fId.value = '';
  els.fTitle.value = els.fSource.value = els.fExcerpt.value = els.fLiturgy.value = els.fRank.value = els.fBody.value = '';
  els.fSeason.value = 'mua-thuong-nien';
  els.fOrder.value  = 1;
  els.fDraft.checked = false;
  els.fManualFill.checked = false;
  els.fSlug.value = '';
  els.fSlug._manual = false;
  els.slugPfx.textContent = 'kinh-sach/mua-thuong-nien/';
  els.formTitle.textContent = 'Thêm bài mới';
  els.btnDelete.style.display  = 'none';
  els.btnDelete2.style.display = 'none';
  els.empty.style.display = 'none';
  els.form.style.display  = 'block';
  els.fTitle.focus();
}

function closeForm() {
  currentId = null;
  els.form.style.display  = 'none';
  els.empty.style.display = 'block';
  renderList();
}

// ─── Form interactions ─────────────────────────────────────────────────────
els.fTitle.addEventListener('input', () => {
  if (!els.fSlug._manual) els.fSlug.value = toSlug(els.fTitle.value);
});
els.fSlug.addEventListener('input', () => { els.fSlug._manual = true; });
els.fSeason.addEventListener('change', () => {
  els.slugPfx.textContent = `kinh-sach/${els.fSeason.value}/`;
});
els.filterSeason.addEventListener('change', renderList);
els.filterSearch.addEventListener('input', renderList);
els.filterEmpty.addEventListener('change', renderList);
els.list.addEventListener('click', e => {
  const row = e.target.closest('.sb-entry-row');
  if (row) openEntry(row.dataset.id);
});
$('btnNew').addEventListener('click', openNew);
$('btnCancel').addEventListener('click', closeForm);
$('btnCancel2').addEventListener('click', closeForm);

// Save
$('sbForm').addEventListener('submit', async e => {
  e.preventDefault();
  const fm = {
    title:     els.fTitle.value.trim(),
    season:    seasonLabel(els.fSeason.value),
    seasonKey: els.fSeason.value,
    source:    els.fSource.value.trim(),
    excerpt:   els.fExcerpt.value.trim(),
    liturgy:   els.fLiturgy.value.trim() || els.fTitle.value.trim(),
    rank:      els.fRank.value.trim(),
    order:     parseInt(els.fOrder.value) || 1,
    draft:     els.fDraft.checked,
  };
  // Remove empty optional fields
  if (!fm.source)  delete fm.source;
  if (!fm.excerpt) delete fm.excerpt;
  if (!fm.rank)    fm.rank = '';
  if (els.fManualFill.checked) fm.manualFill = true;

  const slug = els.fSlug.value.trim() || toSlug(fm.title);
  const body = els.fBody.value;

  try {
    if (isNew) {
      await api('POST', '/api/entry', { seasonKey: fm.seasonKey, slug, fm, body });
      showAlert(`Đã tạo bài "${fm.title}"`);
    } else {
      const oldId = els.fId.value;
      const [oldSeason, ...oldSlugParts] = oldId.split('/');
      const oldSlug = oldSlugParts.join('/');
      const newSlug = slug !== oldSlug ? slug : undefined;
      const result  = await api('PUT', `/api/entry?id=${encodeURIComponent(oldId)}`, { fm, body, newSlug });
      currentId = result.id;
      showAlert(`Đã lưu "${fm.title}"`);
    }
    await loadEntries();
    if (!isNew) openEntry(currentId);
    else closeForm();
  } catch (err) {
    showAlert(err.message, 'error');
  }
});

// Delete
async function doDelete() {
  if (!currentId) return;
  const entry = Object.values(allEntries).flat().find(e => e.id === currentId);
  if (!confirm(`Xóa bài "${entry?.title || currentId}"?\nKhông thể khôi phục.`)) return;
  try {
    await api('DELETE', `/api/entry?id=${encodeURIComponent(currentId)}`);
    showAlert('Đã xóa bài.');
    closeForm();
    await loadEntries();
  } catch (err) {
    showAlert(err.message, 'error');
  }
}
$('btnDelete').addEventListener('click', doDelete);
$('btnDelete2').addEventListener('click', doDelete);

// ─── Init ──────────────────────────────────────────────────────────────────
async function init() {
  try {
    await fetch(`${API}/api/entries`, { signal: AbortSignal.timeout(3000) });
    els.offline.style.display = 'none';
    els.main.style.display    = 'flex';
    await loadEntries();
    // Mở sẵn bài theo ?id= (từ nút edit trang Kinh Sách); ?manual=1 → tick sẵn "fill tay"
    const params = new URLSearchParams(location.search);
    const openId = params.get('id');
    if (openId) {
      try {
        await openEntry(openId);
        if (params.get('manual') === '1' && !els.fManualFill.checked) els.fManualFill.checked = true;
        els.form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } catch { showAlert('Không mở được bài: ' + openId, 'error'); }
    }
  } catch {
    els.offline.style.display = 'flex';
    els.main.style.display    = 'none';
  }
}
$('btnRetry').addEventListener('click', init);
init();
initCaiDat();

// ─── Tab switching ──────────────────────────────────────────────────────────
document.querySelectorAll('.sb-tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.sb-tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const panelId = btn.dataset.panel;
    document.querySelectorAll('.sb-panel').forEach(p => p.style.display = 'none');
    document.getElementById(panelId).style.display = 'block';
    if (panelId === 'panelKinhSach') {
      $('btnNew').style.display = '';
    } else {
      $('btnNew').style.display = 'none';
    }
    if (panelId === 'panelCaiDat') initCaiDat();
    if (panelId === 'panelSaints') loadSaints();
  });
});

// ─── Cài Đặt Trang ─────────────────────────────────────────────────────────
const BANNER_KEYS = {
  'home':               'Trang Chủ',
  'bai-viet':           'Bài Viết',
  'bai-viet-triet-hoc': 'Triết Học',
  'bai-viet-than-hoc':  'Thần Học',
  'readings':           'Kinh Sách',
  'reader':             'Trang Đọc',
  'saints':             'Thánh – Chân Phước',
  'documents':          'Văn Kiện',
  'tu-luat':            'Tu Luật',
  'thu-vien':           'Thư Viện',
  'lich-phung-vu':      'Lịch Phụng Vụ',
  'tu-thuat':           'Tự Thuật',
  'thanh-au-tinh':      'Thánh Augustinô',
  'lich-su-dong':       'Lịch Sử Dòng',
};
const MASTHEAD_KEYS = {
  'bai-viet':     'Bài Viết',
  'readings':     'Kinh Sách',
  'saints':       'Thánh – Chân Phước',
  'thu-vien':     'Thư Viện',
  'lich-phung-vu':'Lịch Phụng Vụ',
  'thanh-au-tinh':'Thánh Augustinô',
  'lich-su-dong': 'Lịch Sử Dòng',
  'on-goi':       'Ơn Gọi',
};
const MASTHEAD_FIELDS = {
  'bai-viet':     ['title','sub'],
  'readings':     ['title','sub','desc'],
  'saints':       ['title','sub'],
  'thu-vien':     ['title','sub'],
  'lich-phung-vu':['title','sub'],
  'thanh-au-tinh':['eyebrow','name','dates','feast'],
  'lich-su-dong': ['eyebrow','title'],
  'on-goi':       ['eyebrow','title','quote','cite'],
};
const MASTHEAD_LABELS = {
  title:'Tiêu đề (h1)',sub:'Phụ đề (sub)',desc:'Mô tả (desc)',
  eyebrow:'Nhãn nhỏ trên (eyebrow)',name:'Tên (h1)',dates:'Năm sinh-mất',feast:'Ngày lễ',
  quote:'Câu trích dẫn (banner)',cite:'Nguồn trích dẫn',
};

let bannerData = {};
let headerData = {};
let availImages = [];
let cdCurrentGroup = null; // 'banner' | 'masthead'
let cdCurrentKey   = null;
let cdCurrentType  = null; // mirrors cdCurrentGroup when a page is opened

async function initCaiDat() {
  try {
    [bannerData, headerData, availImages] = await Promise.all([
      api('GET','/api/banners'),
      api('GET','/api/page-headers'),
      api('GET','/api/banner-images'),
    ]);
  } catch { showAlert('Không tải được dữ liệu cài đặt', 'error'); return; }
  selectGroup('banner');
}

function selectGroup(group) {
  cdCurrentGroup = group;
  cdCurrentKey   = null;
  cdCurrentType  = null;
  document.querySelectorAll('.cd-type-btn').forEach(btn =>
    btn.classList.toggle('active', btn.dataset.group === group));
  renderPageList();
  document.getElementById('cdEmpty').style.display = '';
  document.getElementById('cdForm').style.display = 'none';
}

function renderPageList() {
  const list = document.getElementById('cdPageList');
  if (!cdCurrentGroup) { list.innerHTML = ''; return; }
  const map = cdCurrentGroup === 'banner' ? BANNER_KEYS : MASTHEAD_KEYS;
  list.innerHTML = Object.entries(map).map(([k, label]) =>
    `<div class="cd-page-row ${k === cdCurrentKey ? 'active' : ''}" data-key="${k}">${esc(label)}</div>`
  ).join('');
  list.querySelectorAll('.cd-page-row').forEach(r =>
    r.addEventListener('click', () => openPage(r.dataset.key, cdCurrentGroup)));
}

document.querySelectorAll('.cd-type-btn').forEach(btn =>
  btn.addEventListener('click', () => selectGroup(btn.dataset.group)));

function openPage(key, type) {
  cdCurrentKey = key;
  cdCurrentType = type;
  renderPageList();
  document.getElementById('cdEmpty').style.display = 'none';
  document.getElementById('cdForm').style.display = 'block';
  const keyLabel = type === 'banner' ? (BANNER_KEYS[key] || key) : (MASTHEAD_KEYS[key] || key);
  document.getElementById('cdFormTitle').textContent = keyLabel;

  document.getElementById('cdBannerSection').style.display = type === 'banner' ? '' : 'none';
  document.getElementById('cdMastheadSection').style.display = type === 'masthead' ? '' : 'none';

  if (type === 'banner') {
    const isArray = Array.isArray(bannerData[key]);
    const variants = isArray ? bannerData[key] : bannerData[key] ? [bannerData[key]] : [];
    document.getElementById('cdBannerNote').textContent =
      isArray ? `Banner dạng mảng — ${variants.length} variant (hiển thị ngẫu nhiên)` : '';
    document.getElementById('cdAddVariant').style.display = isArray ? '' : 'none';
    renderVariants(variants, isArray);
  } else {
    renderMasthead(key);
  }
}

function imgSelect(val) {
  const opts = availImages.map(img =>
    `<option value="${esc(img)}" ${img === val ? 'selected' : ''}>${esc(img.split('/').pop())}</option>`
  ).join('');
  return `<select class="cd-img-sel">${opts}</select>`;
}

function variantHtml(v, idx) {
  return `
  <div class="cd-variant" data-idx="${idx}">
    <div class="cd-variant-hd"><span class="cd-variant-num">Variant ${idx + 1}</span></div>
    <div class="sb-field">
      <label>Ảnh banner</label>
      ${imgSelect(v.imageUrl || '')}
    </div>
    <div class="sb-field">
      <label>Alt text</label>
      <input type="text" class="cd-alt" value="${esc(v.altText || '')}" />
    </div>
    <div class="sb-field">
      <label>Câu trích dẫn <small>(quoteText — dùng "" bao văn bản)</small></label>
      <textarea class="cd-qt" rows="3">${esc(v.quoteText || '')}</textarea>
    </div>
    <div class="sb-field">
      <label>Trích nguồn <small>(quoteCite — có thể dùng &lt;em&gt;)</small></label>
      <input type="text" class="cd-qc" value="${esc(v.quoteCite || '')}" />
    </div>
  </div>`;
}

function renderVariants(variants, isArray) {
  document.getElementById('cdVariants').innerHTML = variants.map((v, i) => variantHtml(v, i)).join('');
}

function getVariantsFromDom() {
  return Array.from(document.querySelectorAll('.cd-variant')).map(el => ({
    imageUrl:  el.querySelector('.cd-img-sel').value,
    altText:   el.querySelector('.cd-alt').value.trim(),
    quoteText: el.querySelector('.cd-qt').value.trim(),
    quoteCite: el.querySelector('.cd-qc').value.trim(),
  }));
}

function renderMasthead(key) {
  const fields = MASTHEAD_FIELDS[key] || [];
  const data = headerData[key] || {};
  document.getElementById('cdMastheadFields').innerHTML = fields.map(f => `
    <div class="sb-field">
      <label>${esc(MASTHEAD_LABELS[f] || f)}</label>
      <input type="text" class="cd-mh-field" data-field="${f}" value="${esc(data[f] || '')}" />
    </div>`).join('');
}

document.getElementById('cdAddVariant').addEventListener('click', () => {
  const key = cdCurrentKey;
  const arr = Array.isArray(bannerData[key]) ? [...bannerData[key]] : [];
  arr.push({ imageUrl: availImages[0] || '', altText: '', quoteText: '', quoteCite: '' });
  document.getElementById('cdVariants').innerHTML += variantHtml(arr[arr.length - 1], arr.length - 1);
});

// ── Upload ảnh banner ───────────────────────────────────────────────────────
document.getElementById('cdUploadInput').addEventListener('change', async (e) => {
  const file = e.target.files?.[0];
  if (!file) return;
  const status = document.getElementById('cdUploadStatus');
  status.textContent = 'Đang tải…';
  status.className = 'cd-upload-status';
  try {
    const data = await new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result);
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
    const result = await api('POST', '/api/banner-images', { filename: file.name, data });
    availImages.push(result.url);
    // Cập nhật tất cả select trong cdVariants để thêm option mới
    document.querySelectorAll('.cd-img-sel').forEach(sel => {
      const opt = document.createElement('option');
      opt.value = result.url;
      opt.textContent = result.url.split('/').pop();
      opt.selected = true;
      sel.appendChild(opt);
      // Bỏ chọn các option khác
      Array.from(sel.options).forEach(o => { if (o !== opt) o.selected = false; });
    });
    status.textContent = `Đã tải: ${file.name}`;
    status.className = 'cd-upload-status cd-upload-ok';
  } catch (err) {
    status.textContent = err.message;
    status.className = 'cd-upload-status cd-upload-err';
  }
  e.target.value = ''; // reset để upload lại cùng file nếu cần
});

// ─── Thánh Chân Phước ──────────────────────────────────────────────────────
let allSaints = [];
let currentSaintId = null;

const $s = id => document.getElementById(id);

async function loadSaints() {
  allSaints = await api('GET', '/api/saints');
  renderSaintList();
}

function renderSaintList() {
  const q = $s('saintSearch').value.toLowerCase().trim();
  const onlyEmpty  = $s('saintFilterEmpty').checked;
  const onlyManual = $s('saintFilterManual').checked;
  let rows = allSaints.filter(e => {
    if (q && !e.title.toLowerCase().includes(q)) return false;
    if (onlyEmpty  && e.hasContent) return false;
    if (onlyManual && !e.manualFill) return false;
    return true;
  });
  $s('saintCount').textContent = `${rows.length} mục · ${allSaints.filter(e => !e.hasContent).length} chưa có nội dung`;
  if (!rows.length) {
    $s('saintList').innerHTML = '<p class="sb-list-empty">Không có mục nào.</p>';
    return;
  }
  $s('saintList').innerHTML = rows.map(e => `
    <div class="sb-entry-row ${e.id === currentSaintId ? 'active' : ''} ${e.draft ? 'is-draft' : ''} ${!e.hasContent ? 'is-empty' : ''} ${e.manualFill ? 'is-manual' : ''}"
         data-id="${e.id}">
      <div class="sb-entry-status" title="${e.hasContent ? 'Có nội dung' : 'Chưa có nội dung'}"></div>
      <div class="sb-entry-body">
        <div class="sb-entry-title">${esc(e.title)}</div>
        <div class="sb-entry-meta">
          ${e.feastDay ? `<span>${e.feastDay}/${e.feastMonth}</span>` : ''}
          ${e.draft ? '<span class="sb-tag sb-tag-draft">nháp</span>' : ''}
          ${!e.hasContent ? '<span class="sb-tag sb-tag-empty">trống</span>' : ''}
          ${e.manualFill ? '<span class="sb-tag sb-tag-manual">fill tay</span>' : ''}
        </div>
      </div>
    </div>`).join('');
}

async function openSaint(id) {
  currentSaintId = id;
  const data = await api('GET', `/api/saint?id=${encodeURIComponent(id)}`);
  const fm = data.fm || {};
  $s('saintEditId').value    = id;
  $s('saintTitle').value     = fm.title    || '';
  $s('saintSubtitle').value  = fm.subtitle || '';
  $s('saintRank').value      = fm.rank     || 'none';
  $s('saintFeastDay').value  = fm.feastDay  ?? '';
  $s('saintFeastMonth').value= fm.feastMonth ?? '';
  $s('saintImageFile').value = fm.imageFile || '';
  $s('saintDraft').checked   = !!fm.draft;
  $s('saintManualFill').checked = !!fm.manualFill;
  $s('saintBody').value      = data.body   || '';
  $s('saintFormTitle').textContent = 'Chỉnh sửa: ' + (fm.title || id);
  $s('saintEditorEmpty').style.display = 'none';
  $s('saintForm').style.display = 'block';
  renderSaintList();
}

function closeSaintForm() {
  currentSaintId = null;
  $s('saintForm').style.display  = 'none';
  $s('saintEditorEmpty').style.display = 'block';
  renderSaintList();
}

$s('saintList').addEventListener('click', e => {
  const row = e.target.closest('.sb-entry-row');
  if (row) openSaint(row.dataset.id);
});
$s('saintSearch').addEventListener('input', renderSaintList);
$s('saintFilterEmpty').addEventListener('change', renderSaintList);
$s('saintFilterManual').addEventListener('change', renderSaintList);
$s('saintBtnCancel').addEventListener('click', closeSaintForm);
$s('saintBtnCancel2').addEventListener('click', closeSaintForm);

$s('saintForm').addEventListener('submit', async e => {
  e.preventDefault();
  const id = $s('saintEditId').value;
  const fm = {
    title:      $s('saintTitle').value.trim(),
    subtitle:   $s('saintSubtitle').value.trim() || undefined,
    rank:       $s('saintRank').value,
    feastDay:   parseInt($s('saintFeastDay').value) || undefined,
    feastMonth: parseInt($s('saintFeastMonth').value) || undefined,
    imageFile:  $s('saintImageFile').value.trim() || undefined,
    draft:      $s('saintDraft').checked,
  };
  if ($s('saintManualFill').checked) fm.manualFill = true;
  // clean undefined
  Object.keys(fm).forEach(k => fm[k] === undefined && delete fm[k]);
  const body = $s('saintBody').value;
  try {
    await api('PUT', `/api/saint?id=${encodeURIComponent(id)}`, { fm, body });
    showAlert(`Đã lưu "${fm.title}"`);
    await loadSaints();
    openSaint(id);
  } catch (err) {
    showAlert(err.message, 'error');
  }
});

document.getElementById('cdSaveBtn').addEventListener('click', async () => {
  const key = cdCurrentKey;
  const type = cdCurrentType;
  if (!key || !type) return;
  try {
    if (type === 'banner') {
      const variants = getVariantsFromDom();
      const isArray = Array.isArray(bannerData[key]);
      const newBanner = isArray ? variants : variants[0];
      await api('PUT', `/api/banners/${encodeURIComponent(key)}`, newBanner);
      bannerData[key] = newBanner;
    } else {
      const newHeader = {};
      document.querySelectorAll('.cd-mh-field').forEach(inp => {
        newHeader[inp.dataset.field] = inp.value.trim();
      });
      await api('PUT', `/api/page-headers/${encodeURIComponent(key)}`, newHeader);
      headerData[key] = newHeader;
    }
    const labelMap = type === 'banner' ? BANNER_KEYS : MASTHEAD_KEYS;
    showAlert(`Đã lưu "${labelMap[key] || key}"`);
  } catch (err) {
    showAlert(err.message, 'error');
  }
});
</script>

