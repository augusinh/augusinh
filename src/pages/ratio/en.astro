---
import { getEntry } from 'astro:content';
import DocumentReader from '../../components/DocumentReader.astro';
const entry = await getEntry('documents', 'ratio-en');
if (!entry) return Astro.redirect('/404');
---
<DocumentReader entry={entry} langs={[
  { label: 'Tiếng Việt', href: '/ratio/', current: false, id: 'ratio-vi' },
  { label: 'English', href: '/ratio/en/', current: true, id: 'ratio-en' },
]} />
